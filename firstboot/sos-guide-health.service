[Unit]
Description=SOS-GUIDE Health Check — Vérification intégrité SHA256 toutes les 5 minutes
Documentation=https://sos-guide.fr
After=network.target hostapd.service dnsmasq.service nginx.service
# FIX v2.3 : Requires=sos-guide-health.timer supprimé
# Le timer active ce service — le service ne doit pas dépendre du timer
# (dépendance circulaire : timer → service → timer)
# PartOf= permet d'arrêter le service quand le timer est arrêté (comportement souhaité)
PartOf=sos-guide-health.timer

[Service]
Type=oneshot
ExecStart=/usr/local/bin/sos-guide-boot-check.sh
# Pas de réseau requis pour la vérification locale
PrivateNetwork=no
# Accès restreint
NoNewPrivileges=yes
ProtectSystem=no
ReadWritePaths=/var/log /run/sos-guide
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sos-guide-health

[Install]
WantedBy=multi-user.target
