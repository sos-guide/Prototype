  "principes": [
    {
      "icon": "📢", "titre": "ALARMER", "desc": "Alarmér redningstjenesten", "colorClass": "card-bleu",
      "contenu": {
        "steps": [
          "Nødnumre: 112 (Alarmcentralen).",
          "Angiv: Hvor? (præcis sted), Hvad? (ulykkestype), Hvem? (antal tilskadekomne, tilstand).",
          "Læg ikke på først – lad operatøren afslutte opkaldet.",
          "Brug en lokaliseringsapp hvis muligt.",
          "Hvis du er alene og ikke kan tale, ring 112 og lad linjen være åben."
        ]
      }
    },
    {
      "icon": "🩺", "titre": "REDDE", "desc": "Yd førstehjælp", "colorClass": "card-blanc",
      "contenu": {
        "steps": [
          "Vurder bevidsthed (tal, rør), kontrollér vejrtrækning.",
          "Ingen vejrtrækning: start straks hjertemassage (100-120 tryk/min).",
          "Aflåst sideleje hvis bevidstløs men trækker vejret.",
          "Blødning: tryk direkte på såret. Brug kun trykforbinding hvis tryk er utilstrækkeligt.",
          "Giv aldrig en bevidstløs person noget at drikke.",
          "Berolig den tilskadekomne og dæk til for at undgå hypotermi."
        ]
      }
    },
    {
      "icon": "🛡️", "titre": "BESKYTTE", "desc": "Sørg for sikkerhed", "colorClass": "card-rouge",
      "contenu": {
        "steps": [
          "Fjern den tilskadekomne fra umiddelbar fare (brand, trafik, sammenstyrtning).",
          "Afmærk området (advarselstrekant, havariblink).",
          "Beskyt dig selv: handsker, maske hvis tilgængelig.",
          "Afbryd farekilder (gas, elektricitet).",
          "Flyt ikke en tilskadekommen med mistanke om rygsøjleskade."
        ]
      }
    }
  ],
