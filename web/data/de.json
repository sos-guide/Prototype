      "icon": "📢", "titre": "ALARMIEREN", "desc": "Rettungsdienst alarmieren", "colorClass": "card-bleu",
      "contenu": {
        "steps": [
          "Notrufnummern: 112 (Europa), 110 (Polizei).",
          "Angaben: Wo? (genauer Ort), Was? (Unfallart), Wer? (Anzahl Verletzte, Zustand).",
          "Nicht zuerst auflegen – der Disponent beendet das Gespräch.",
          "Wenn möglich Standort-App nutzen.",
          "Wenn Sie allein sind und nicht sprechen können, wählen Sie 112 und lassen Sie die Leitung offen."
        ]
      }
    },
    {
      "icon": "🩺", "titre": "HELFEN", "desc": "Erste Hilfe leisten", "colorClass": "card-blanc",
      "contenu": {
        "steps": [
          "Bewusstsein prüfen (ansprechen, berühren), Atmung kontrollieren.",
          "Keine Atmung: sofort Herzdruckmassage (100-120/min).",
          "Stabile Seitenlage bei Bewusstlosigkeit mit Atmung.",
          "Blutung: Wunde abdrücken. Abbinden nur wenn Druck nicht ausreicht.",
          "Bewusstlosen niemals zu trinken geben.",
          "Betroffenen beruhigen und vor Unterkühlung schützen."
        ]
      }
    },
    {
      "icon": "🛡️", "titre": "SCHÜTZEN", "desc": "Sicherheit herstellen", "colorClass": "card-rouge",
      "contenu": {
        "steps": [
          "Aus unmittelbarer Gefahr bringen (Feuer, Verkehr, Einsturz).",
          "Unfallstelle absichern (Warndreieck, Warnblinker).",
          "Eigenschutz: Handschuhe, Maske falls vorhanden.",
          "Gefahrenquellen abschalten (Gas, Strom).",
          "Verletzte mit Verdacht auf Wirbelsäulenverletzung nicht bewegen."
        ]
      }
    }
