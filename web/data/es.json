  "principes": [
    {
      "icon": "📢", "titre": "ALERTAR", "desc": "Dar la alarma a los servicios de emergencia", "colorClass": "card-bleu",
      "contenu": {
        "steps": [
          "Números de emergencia: 15 (SAMU), 17 (Policía), 18 (Bomberos), 112 (Europa), 114 (sordos).",
          "Indica: ¿Dónde? (lugar exacto), ¿Qué? (tipo de accidente), ¿Quién? (número de víctimas, estado).",
          "No cuelgues primero: deja que el operador termine la llamada.",
          "Usa una app de localización si es posible.",
          "Si estás solo y no puedes hablar, marca 112 y deja la línea abierta."
        ]
      }
    },
    {
      "icon": "🩺", "titre": "SOCORRER", "desc": "Realizar los primeros gestos", "colorClass": "card-blanc",
      "contenu": {
        "steps": [
          "Evaluar la conciencia (hablar, tocar), verificar la respiración.",
          "Si no respira: iniciar masaje cardíaco (100-120 compresiones/min).",
          "Posición Lateral de Seguridad (PLS) si está inconsciente pero respira.",
          "Hemorragia: comprimir la herida. Torniquete solo si la compresión falla.",
          "Nunca dar de beber a una persona inconsciente.",
          "Tranquilizar a la víctima y cubrirla para evitar hipotermia."
        ]
      }
    },
    {
      "icon": "🛡️", "titre": "PROTEGER", "desc": "Poner a salvo", "colorClass": "card-rouge",
      "contenu": {
        "steps": [
          "Alejar a la víctima del peligro inmediato (fuego, tráfico, derrumbe).",
          "Balizar la zona (triángulo de señalización, luces de emergencia).",
          "Protegerse uno mismo: guantes, mascarilla si hay.",
          "Cortar fuentes de peligro (gas, electricidad).",
          "No mover a un herido con sospecha de lesión medular."
        ]
      }
    }
  ],
