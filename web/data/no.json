      "icon": "📢", "titre": "VARSLE", "desc": "Varsle nødetatene", "colorClass": "card-bleu",
      "contenu": {
        "steps": [
          "Nødnumre: 113 (ambulanse), 112 (politi), 110 (brann).",
          "Oppgi: Hvor? (nøyaktig sted), Hva? (type ulykke), Hvem? (antall skadde, tilstand).",
          "Ikke legg på først – la operatøren avslutte samtalen.",
          "Bruk en posisjoneringsapp hvis mulig.",
          "Hvis du er alene og ikke kan snakke, ring 112 og la linjen være åpen."
        ]
      }
    },
    {
      "icon": "🩺", "titre": "REDDE", "desc": "Gi førstehjelp", "colorClass": "card-blanc",
      "contenu": {
        "steps": [
          "Vurder bevissthet (snakk, berør), sjekk pust.",
          "Ingen pust: start umiddelbart hjertekompresjoner (100-120/min).",
          "Stabilt sideleie hvis bevisstløs men puster.",
          "Blødning: trykk direkte på såret. Bruk trykkforband kun hvis trykk ikke er nok.",
          "Gi aldri en bevisstløs person noe å drikke.",
          "Berolig den skadde og dekk til for å unngå hypotermi."
        ]
      }
    },
    {
      "icon": "🛡️", "titre": "BESKYTTE", "desc": "Sørg for sikkerhet", "colorClass": "card-rouge",
      "contenu": {
        "steps": [
          "Fjern den skadde fra umiddelbar fare (brann, trafikk, ras).",
          "Sikre stedet (varseltrekant, nødblink).",
          "Beskytt deg selv: hansker, maske hvis tilgjengelig.",
          "Koble fra farekilder (gass, strøm).",
          "Flytt ikke en skadd person ved mistanke om ryggmargsskade."
        ]
      }
    }
  ],
