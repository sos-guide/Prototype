  "principes": [
    {
      "icon": "📢", "titre": "ALLERTARE", "desc": "Dare l'allarme ai soccorsi", "colorClass": "card-bleu",
      "contenu": {
        "steps": [
          "Numeri di emergenza: 112 (Unico), 113 (Polizia), 115 (Vigili Fuoco), 118 (Sanitario).",
          "Indicare: Dove? (luogo esatto), Cosa? (tipo di incidente), Chi? (numero vittime, condizioni).",
          "Non riagganciare per primi: lasciare che l'operatore chiuda la chiamata.",
          "Usare un'app di localizzazione se possibile.",
          "Se soli e impossibilitati a parlare, comporre 112 e lasciare la linea aperta."
        ]
      }
    },
    {
      "icon": "🩺", "titre": "SOCCORRERE", "desc": "Prestare i primi gesti", "colorClass": "card-blanc",
      "contenu": {
        "steps": [
          "Valutare coscienza (parlare, toccare), verificare respiro.",
          "Se non respira: iniziare massaggio cardiaco (100-120 compressioni/min).",
          "Posizione Laterale di Sicurezza (PLS) se incosciente ma respira.",
          "Emorragia: comprimere la ferita. Laccio emostatico solo se compressione inefficace.",
          "Non dare mai da bere a una persona incosciente.",
          "Rassicurare la vittima e coprirla per evitare ipotermia."
        ]
      }
    },
    {
      "icon": "🛡️", "titre": "PROTEGGERE", "desc": "Mettere in sicurezza", "colorClass": "card-rouge",
      "contenu": {
        "steps": [
          "Allontanare la vittima dal pericolo immediato (fuoco, traffico, crollo).",
          "Delimitare la zona (triangolo, luci di emergenza).",
          "Proteggersi: guanti, mascherina se disponibile.",
          "Interrompere fonti di pericolo (gas, elettricità).",
          "Non spostare un ferito con sospetto trauma spinale."
        ]
      }
    }
  ],
