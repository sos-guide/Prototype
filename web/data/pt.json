  "principes": [
    {
      "icon": "📢", "titre": "ALERTAR", "desc": "Dar o alerta aos serviços de emergência", "colorClass": "card-bleu",
      "contenu": {
        "steps": [
          "Números de emergência: 112 (número único europeu).",
          "Indique: Onde? (local exato), O quê? (tipo de acidente), Quem? (número de vítimas, estado).",
          "Não desligue primeiro: deixe o operador terminar a chamada.",
          "Utilize uma aplicação de localização se possível.",
          "Se estiver sozinho e não puder falar, marque 112 e deixe a linha aberta."
        ]
      }
    },
    {
      "icon": "🩺", "titre": "SOCORRER", "desc": "Prestar os primeiros gestos", "colorClass": "card-blanc",
      "contenu": {
        "steps": [
          "Avaliar a consciência (falar, tocar), verificar respiração.",
          "Se não respira: iniciar massagem cardíaca (100-120 compressões/min).",
          "Posição Lateral de Segurança (PLS) se inconsciente mas respira.",
          "Hemorragia: comprimir a ferida. Torniquete só se a compressão falhar.",
          "Nunca dar de beber a uma pessoa inconsciente.",
          "Tranquilizar a vítima e cobri-la para evitar hipotermia."
        ]
      }
    },
    {
      "icon": "🛡️", "titre": "PROTEGER", "desc": "Colocar em segurança", "colorClass": "card-rouge",
      "contenu": {
        "steps": [
          "Afastar a vítima de perigo imediato (fogo, trânsito, desabamento).",
          "Sinalizar a zona (triângulo, luzes de emergência).",
          "Proteger-se: luvas, máscara se disponível.",
          "Cortar fontes de perigo (gás, eletricidade).",
          "Não mover um ferido com suspeita de trauma raquidiano."
        ]
      }
    }
  ],
